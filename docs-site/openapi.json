    "/api/v1/journal/entries/{date}": {
      "get": {
        "summary": "Get journal entry by date",
        "description": "Retrieves a specific journal entry for a given date",
        "tags": ["Journal"],
        "security": [{"BearerAuth": []}],
        "parameters": [
          {
            "name": "date",
            "in": "path",
            "required": true,
            "description": "Date of the journal entry (YYYY-MM-DD)",
            "schema": {"type": "string", "format": "date"},
            "example": "2025-01-15"
          }
        ],
        "responses": {
          "200": {
            "description": "Journal entry retrieved successfully",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/JournalEntry"}
              }
            }
          },
          "404": {"description": "Journal entry not found for this date"},
          "401": {"description": "Unauthorized"},
          "500": {"description": "Internal server error"}
        }
      },
      "put": {
        "summary": "Update journal entry",
        "description": "Updates an existing journal entry for a specific date",
        "tags": ["Journal"],
        "security": [{"BearerAuth": []}],
        "parameters": [
          {
            "name": "date",
            "in": "path",
            "required": true,
            "description": "Date of the journal entry (YYYY-MM-DD)",
            "schema": {"type": "string", "format": "date"},
            "example": "2025-01-15"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {"$ref": "#/components/schemas/JournalEntryUpdate"}
            }
          }
        },
        "responses": {
          "200": {
            "description": "Journal entry updated successfully",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/JournalEntry"}
              }
            }
          },
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"},
          "404": {"description": "Journal entry not found"},
          "500": {"description": "Internal server error"}
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT token obtained from authentication"
      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "id": {"type": "string", "description": "Unique user identifier"},
          "email": {"type": "string", "format": "email", "description": "User's email address"},
          "created_at": {"type": "string", "format": "date-time", "description": "Account creation timestamp"},
          "updated_at": {"type": "string", "format": "date-time", "description": "Last update timestamp"}
        },
        "required": ["id", "email", "created_at"]
      },
      "UserUpdate": {
        "type": "object",
        "properties": {
          "email": {"type": "string", "format": "email", "description": "Updated email address"}
        }
      },
      "UserPreferences": {
        "type": "object",
        "properties": {
          "protocols": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Active protocol identifiers"
          },
          "quick_supplements": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Frequently used supplements"
          },
          "quick_medications": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Frequently used medications"
          },
          "quick_foods": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Frequently consumed foods"
          },
          "quick_symptoms": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Frequently tracked symptoms"
          },
          "quick_detox": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Frequently used detox methods"
          },
          "setup_complete": {"type": "boolean", "description": "Whether initial setup is complete"}
        }
      },
      "UserPreferencesUpdate": {
        "type": "object",
        "properties": {
          "protocols": {"type": "array", "items": {"type": "string"}},
          "quick_supplements": {"type": "array", "items": {"type": "string"}},
          "quick_medications": {"type": "array", "items": {"type": "string"}},
          "quick_foods": {"type": "array", "items": {"type": "string"}},
          "quick_symptoms": {"type": "array", "items": {"type": "string"}},
          "quick_detox": {"type": "array", "items": {"type": "string"}},
          "setup_complete": {"type": "boolean"}
        }
      },
      "Protocol": {
        "type": "object",
        "properties": {
          "id": {"type": "string", "description": "Protocol identifier"},
          "name": {"type": "string", "description": "Protocol display name"},
          "description": {"type": "string", "description": "Protocol description"},
          "category": {"type": "string", "description": "Protocol category"},
          "phase": {"type": "string", "description": "Current phase (elimination, reintroduction, maintenance)"}
        },
        "required": ["id", "name", "description"]
      },
      "Food": {
        "type": "object",
        "properties": {
          "id": {"type": "string", "description": "Food identifier"},
          "name": {"type": "string", "description": "Food name"},
          "category": {"type": "string", "description": "Food category"},
          "protocol_compliance": {
            "type": "object",
            "description": "Protocol compliance status",
            "additionalProperties": {"type": "boolean"}
          }
        },
        "required": ["id", "name"]
      },
      "Symptom": {
        "type": "object",
        "properties": {
          "id": {"type": "string", "description": "Symptom identifier"},
          "name": {"type": "string", "description": "Symptom name"},
          "category": {"type": "string", "description": "Symptom category"},
          "severity_scale": {"type": "string", "description": "Severity measurement scale"}
        },
        "required": ["id", "name"]
      },
      "Supplement": {
        "type": "object",
        "properties": {
          "id": {"type": "string", "description": "Supplement identifier"},
          "name": {"type": "string", "description": "Supplement name"},
          "category": {"type": "string", "description": "Supplement category"},
          "dosage_info": {"type": "string", "description": "Dosage information"}
        },
        "required": ["id", "name"]
      },
      "Medication": {
        "type": "object",

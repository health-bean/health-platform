{
  "openapi": "3.0.0",
  "info": {
    "title": "FILO Health Platform API",
    "description": "Comprehensive health tracking and protocol management API for chronic illness management. This API provides endpoints for managing user health data, protocols, timeline entries, correlations, and insights.",
    "version": "1.0.0",
    "contact": {
      "name": "FILO Health Platform",
      "url": "https://deebyrne26.github.io/health-platform/"
    },
    "license": {
      "name": "MIT"
    }
  },
  "servers": [
    {
      "url": "https://suhoxvn8ik.execute-api.us-east-1.amazonaws.com/dev",
      "description": "Production API"
    }
  ],
  "paths": {
    "/api/v1/protocols": {
      "get": {
        "summary": "Get all available protocols",
        "description": "Retrieves all health protocols available in the system",
        "tags": ["Protocols"],
        "responses": {
          "200": {
            "description": "Protocols retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {"$ref": "#/components/schemas/Protocol"}
                }
              }
            }
          },
          "500": {"description": "Internal server error"}
        }
      }
    },
    "/api/v1/foods/search": {
      "get": {
        "summary": "Search for foods",
        "description": "Search for foods with optional protocol compliance filtering",
        "tags": ["Search"],
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "description": "Search query for food names",
            "schema": {"type": "string"},
            "example": "apple"
          },
          {
            "name": "protocol",
            "in": "query",
            "required": false,
            "description": "Filter by protocol compliance",
            "schema": {"type": "string"},
            "example": "aip-core"
          }
        ],
        "responses": {
          "200": {
            "description": "Food search results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {"$ref": "#/components/schemas/Food"}
                }
              }
            }
          },
          "400": {"description": "Bad request - Missing search query"},
          "500": {"description": "Internal server error"}
        }
      }
    },
    "/api/v1/foods/by-protocol": {
      "get": {
        "summary": "Get foods by protocol",
        "description": "Retrieves foods that are compliant with a specific protocol",
        "tags": ["Search"],
        "parameters": [
          {
            "name": "protocol",
            "in": "query",
            "required": true,
            "description": "Protocol identifier",
            "schema": {"type": "string"},
            "example": "aip-core"
          }
        ],
        "responses": {
          "200": {
            "description": "Protocol-compliant foods",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {"$ref": "#/components/schemas/Food"}
                }
              }
            }
          },
          "400": {"description": "Bad request - Missing protocol parameter"},
          "500": {"description": "Internal server error"}
        }
      }
    },
